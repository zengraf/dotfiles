{
  "title": "Router Overview",
  "uid": "router-overview",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Probe Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-icmp\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ICMP Latency",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "probe_icmp_duration_seconds{job=\"blackbox-icmp\", phase=\"rtt\"} and on(instance) probe_success{job=\"blackbox-icmp\"} == 1",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DNS Probe Latency",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "probe_dns_lookup_time_seconds{job=\"blackbox-dns\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations"
        }
      },
      "options": {
        "colorMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "System Resources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Load Average",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Memory Usage",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Filesystem Usage",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})",
          "legendFormat": "/",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Network Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Interface Traffic",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[5m]) * 8",
          "legendFormat": "{{device}} rx",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[5m]) * 8",
          "legendFormat": "{{device}} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Conntrack Entries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "expr": "node_nf_conntrack_entries",
          "legendFormat": "entries",
          "refId": "A"
        },
        {
          "expr": "node_nf_conntrack_entries_limit",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "limit" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 14,
      "type": "row",
      "title": "DNS (Unbound)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Query Rate",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(unbound_queries_total[5m]))",
          "legendFormat": "queries/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 4, "x": 6, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(unbound_cache_hits_total[5m])) / (sum(rate(unbound_cache_hits_total[5m])) + sum(rate(unbound_cache_misses_total[5m])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Answer RCodes",
      "gridPos": { "h": 8, "w": 8, "x": 10, "y": 28 },
      "targets": [
        {
          "expr": "sum by (rcode) (rate(unbound_answer_rcodes_total[5m]))",
          "legendFormat": "{{rcode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Avg Recursion Time",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "targets": [
        {
          "expr": "unbound_recursion_time_seconds_avg",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "colorMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 19,
      "type": "row",
      "title": "DHCP (Kea)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Active Leases",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "targets": [
        {
          "expr": "kea_dhcp4_addresses_assigned_total{pool=\"\"}",
          "legendFormat": "{{subnet}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "colorMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Pool Utilization",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "targets": [
        {
          "expr": "kea_dhcp4_addresses_assigned_total{pool=\"\"} / kea_dhcp4_addresses_total{pool=\"\"}",
          "legendFormat": "{{subnet}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 22,
      "type": "row",
      "title": "UniFi Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Connected Clients",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 46 },
      "targets": [
        {
          "expr": "count(unpoller_client_transmit_bytes_total) by (site_name)",
          "legendFormat": "{{site_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "colorMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Device Uptime",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 46 },
      "targets": [
        {
          "expr": "unpoller_device_uptime_seconds",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations"
        }
      },
      "options": {
        "colorMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Device Throughput",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 },
      "targets": [
        {
          "expr": "rate(unpoller_device_receive_bytes_total[5m]) * 8",
          "legendFormat": "{{name}} rx",
          "refId": "A"
        },
        {
          "expr": "-rate(unpoller_device_transmit_bytes_total[5m]) * 8",
          "legendFormat": "{{name}} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    }
  ]
}
